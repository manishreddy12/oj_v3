// ─────────────────────────────────────────────────────────────────────────────
// CodeView CI/CD Pipeline
//
// Prerequisites (configure in Jenkins UI):
//   Credentials:
//     - dockerhub-credentials  : Username/Password  (DockerHub)
//     - kubeconfig             : Secret file        (~/.kube/config)
//   Plugins required:
//     - Docker Pipeline
//     - Kubernetes CLI Plugin
//     - Ansible Plugin
//     - Pipeline Stage View
//
// Environment variables to set in Jenkins → Configure → Global Properties:
//   DOCKERHUB_USERNAME   your DockerHub username
//   K8S_NAMESPACE        codeview
// ─────────────────────────────────────────────────────────────────────────────

pipeline {
    agent any

    environment {
        DOCKERHUB_USER  = "manishr09"
        IMAGE_API       = "${DOCKERHUB_USER}/codeview-api"
        IMAGE_EXEC      = "${DOCKERHUB_USER}/codeview-execution"
        IMAGE_FRONTEND  = "${DOCKERHUB_USER}/codeview-frontend"
        K8S_NS          = "codeview"
        // Tag with build number + short commit SHA for traceability
        IMAGE_TAG       = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()       // no parallel builds on same branch
    }

    stages {

        // ── 1. Checkout ────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    echo "Building: ${env.GIT_COMMIT_MSG}"
                }
            }
        }

        // ── 2. Install Dependencies ────────────────────────────────────────
        stage('Install Dependencies') {
            parallel {
                stage('API deps') {
                    steps {
                        dir('api-service') {
                            sh 'npm ci'
                        }
                    }
                }
                stage('Execution deps') {
                    steps {
                        dir('execution-service') {
                            sh 'npm ci'
                        }
                    }
                }
                stage('Frontend deps') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci'
                        }
                    }
                }
            }
        }

        //  3. Tests 
        stage('Tests') {
            parallel {
                stage('API tests') {
                    steps {
                        dir('api-service') {
                            sh 'npm test -- --forceExit --passWithNoTests'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'api-service/junit.xml'
                        }
                    }
                }
                stage('Execution tests') {
                    steps {
                        dir('execution-service') {
                            sh 'npm test -- --forceExit --passWithNoTests'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'execution-service/junit.xml'
                        }
                    }
                }
            }
        }

        // ── 4. Build Docker Images ─────────────────────────────────────────
        stage('Build Images') {
            parallel {
                stage('Build API') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                            sh """
                                docker build \
                                  -f api-service/Dockerfile \
                                  -t ${IMAGE_API}:${IMAGE_TAG} \
                                  -t ${IMAGE_API}:latest \
                                  .
                            """
                        }
                    }
                }
                stage('Build Execution') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                            sh """
                                docker build \
                                  -f execution-service/Dockerfile \
                                  -t ${IMAGE_EXEC}:${IMAGE_TAG} \
                                  -t ${IMAGE_EXEC}:latest \
                                  .
                            """
                        }
                    }
                }
                stage('Build Frontend') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                            sh """
                                docker build \
                                  -f frontend/Dockerfile \
                                  --build-arg VITE_API_URL=${env.VITE_API_URL ?: 'http://codeview.local'} \
                                  -t ${IMAGE_FRONTEND}:${IMAGE_TAG} \
                                  -t ${IMAGE_FRONTEND}:latest \
                                  .
                            """
                        }
                    }
                }
            }
        }
        
        // stage('Build Images') {
        //     parallel {
        //         stage('Build API') {
        //             steps {
        //                 sh """
        //                     docker build \
        //                       -f api-service/Dockerfile \
        //                       -t ${IMAGE_API}:${IMAGE_TAG} \
        //                       -t ${IMAGE_API}:latest \
        //                       .
        //                 """
        //             }
        //         }
        //         stage('Build Execution') {
        //             steps {
        //                 sh """
        //                     docker build \
        //                       -f execution-service/Dockerfile \
        //                       -t ${IMAGE_EXEC}:${IMAGE_TAG} \
        //                       -t ${IMAGE_EXEC}:latest \
        //                       .
        //                 """
        //             }
        //         }
        //         stage('Build Frontend') {
        //             steps {
        //                 sh """
        //                     docker build \
        //                       -f frontend/Dockerfile \
        //                       --build-arg VITE_API_URL=${env.VITE_API_URL ?: 'http://codeview.local'} \
        //                       -t ${IMAGE_FRONTEND}:${IMAGE_TAG} \
        //                       -t ${IMAGE_FRONTEND}:latest \
        //                       .
        //                 """
        //             }
        //         }
        //     }
        // }

        // ── 5. Security Scan (Trivy) ───────────────────────────────────────
        stage('Security Scan') {
            steps {
                script {
                    // Requires trivy installed: https://aquasecurity.github.io/trivy
                    sh """
                        trivy image --exit-code 0 \
                          --severity HIGH,CRITICAL \
                          --no-progress \
                          ${IMAGE_API}:${IMAGE_TAG} \
                          || true
                    """
                }
            }
        }

        // ── 6. Push to DockerHub ───────────────────────────────────────────
        stage('Push Images') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }

            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    // Remove stale Docker session
                    sh 'docker logout || true'
                    sh 'rm -f ~/.docker/config.json || true'

                    // Fresh login using new token
                    sh '''
                        echo "$DOCKER_PASS" | docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin
                    '''

                    sh """
                        docker push ${IMAGE_API}:${IMAGE_TAG}
                        docker push ${IMAGE_API}:latest

                        docker push ${IMAGE_EXEC}:${IMAGE_TAG}
                        docker push ${IMAGE_EXEC}:latest

                        docker push ${IMAGE_FRONTEND}:${IMAGE_TAG}
                        docker push ${IMAGE_FRONTEND}:latest
                    """
                }
            }

            post {
                always {
                    sh 'docker logout || true'
                }
            }
        }
        
        // stage('Push Images') {
        //     when {
        //         anyOf {
        //             branch 'main'
        //             branch 'master'
        //         }
        //     }
        //     steps {
        //         withCredentials([usernamePassword(
        //             credentialsId: 'docker-hub-creds',
        //             usernameVariable: 'DOCKER_USER',
        //             passwordVariable: 'DOCKER_PASS'
        //         )]) {
        //             sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
        //             sh """
        //                 docker push ${IMAGE_API}:${IMAGE_TAG}
        //                 docker push ${IMAGE_API}:latest
        //                 docker push ${IMAGE_EXEC}:${IMAGE_TAG}
        //                 docker push ${IMAGE_EXEC}:latest
        //                 docker push ${IMAGE_FRONTEND}:${IMAGE_TAG}
        //                 docker push ${IMAGE_FRONTEND}:latest
        //             """
        //         }
        //     }
        //     post {
        //         always {
        //             sh 'docker logout'
        //         }
        //     }
        // }

        // ── 7. Deploy via Ansible ──────────────────────────────────────────
        stage('Deploy to Kubernetes') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    // Update image tags in manifests and apply via Ansible
                    ansiblePlaybook(
                        playbook:   'devops/ansible/playbooks/deploy.yml',
                        inventory:  'devops/ansible/inventory.ini',
                        extras:     "-e image_tag=${IMAGE_TAG} -e dockerhub_user=${DOCKERHUB_USER}",
                        colorized:  true
                    )
                }
            }
        }

        // ── 8. Smoke Test ──────────────────────────────────────────────────
        stage('Smoke Test') {
            when {
                anyOf { branch 'main'; branch 'master' }
            }
            steps {
                script {
                    // Wait for rollout to complete, then hit /api/health
                    sh """
                        kubectl rollout status deployment/api-service \
                          -n ${K8S_NS} --timeout=120s
                        kubectl rollout status deployment/execution-service \
                          -n ${K8S_NS} --timeout=120s
                    """
                    // Port-forward temporarily and test
                    sh """
                        kubectl port-forward svc/api-service 8099:5000 \
                          -n ${K8S_NS} &
                        PF_PID=\$!
                        sleep 5
                        curl -f http://localhost:8099/api/health || \
                          (kill \$PF_PID; exit 1)
                        kill \$PF_PID
                    """
                }
            }
        }

        // ── 9. Integration Tests ──────────────────────────────────────────
        stage('Integration Tests') {
            when {
                anyOf { branch 'main'; branch 'master' }
            }
            steps {
                script {
                    // Install test dependencies
                    dir('tests') {
                        sh 'npm ci'
                    }

                    // Port-forward both services for testing
                    sh """
                        kubectl port-forward svc/api-service 8099:5000 \
                          -n ${K8S_NS} &
                        API_PF_PID=\$!
                        kubectl port-forward svc/execution-service 8098:5001 \
                          -n ${K8S_NS} &
                        EXEC_PF_PID=\$!
                        sleep 8

                        # Run integration tests
                        cd tests
                        API_URL=http://localhost:8099 \
                        EXEC_URL=http://localhost:8098 \
                        npx jest k8s-integration.test.js \
                          --forceExit --ci \
                          --reporters=default --reporters=jest-junit || \
                          TEST_EXIT=\$?

                        # Cleanup port-forwards
                        kill \$API_PF_PID \$EXEC_PF_PID 2>/dev/null || true
                        exit \${TEST_EXIT:-0}
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'tests/junit.xml'
                }
            }
        }

        // ── 10. HPA Validation ────────────────────────────────────────────
        stage('HPA Validation') {
            when {
                anyOf { branch 'main'; branch 'master' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    dir('tests') {
                        sh """
                            K8S_NAMESPACE=${K8S_NS} \
                            npx jest hpa-validation.test.js \
                              --forceExit --ci \
                              --reporters=default --reporters=jest-junit
                        """
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'tests/junit.xml'
                }
            }
        }
    }

    // ── Post-pipeline actions ──────────────────────────────────────────────

    post {
        always {
            // Clean dangling Docker images to save disk space
            sh 'docker image prune -f || true'
            cleanWs()
        }
        success {
            echo "✅ Pipeline succeeded — build ${env.BUILD_NUMBER} deployed."
        }
        failure {
            echo "❌ Pipeline failed — check the logs above."
            // Uncomment if you have mail configured:
            // mail to: 'team@example.com',
            //      subject: "Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            //      body: "See: ${env.BUILD_URL}"
        }
    }
}
