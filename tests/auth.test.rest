### ========================================
### AUTH ROUTES - Test Cases
### Base URL: http://localhost:5000/api/auth
### ========================================


### ----------------------------------------
### 1. Register - Success (New User)
### ----------------------------------------
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "username": "testuser01",
  "email": "testuser01@example.com",
  "password": "password123",
  "role": "student"
}

### Expected: 201
### { success: true, message: "User registered successfully", data: { user: {...} } }


### ----------------------------------------
### 2. Register - Validation Error (Short Password)
### ----------------------------------------
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "username": "testuser02",
  "email": "testuser02@example.com",
  "password": "12"
}

### Expected: 400
### { success: false, message: "Password must be at least 6 characters" }


### ----------------------------------------
### 3. Register - Validation Error (Invalid Email)
### ----------------------------------------
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "username": "testuser03",
  "email": "not-an-email",
  "password": "password123"
}

### Expected: 400
### { success: false, message: "A valid email is required" }


### ----------------------------------------
### 4. Login - Success
### ----------------------------------------
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "testuser01@example.com",
  "password": "password123"
}

### Expected: 200
### { success: true, message: "Login successful", data: { token: "..." } }


### ----------------------------------------
### 5. Login - Missing Password
### ----------------------------------------
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "testuser01@example.com"
}

### Expected: 400
### { success: false, message: "Password is required" }


### ----------------------------------------
### 6. Login - Invalid Credentials
### ----------------------------------------
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "nonexistent@example.com",
  "password": "wrongpassword"
}

### Expected: 401
### { success: false, message: "Invalid email or password" }
