### ----------------------------------------
### 4. Create Problem - Success (Requires Auth: problem_setter/admin)
### ----------------------------------------
POST http://localhost:5000/api/problems
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Two Sum",
  "description": "Given an array of integers, return indices of the two numbers that add up to a specific target.",
  "difficulty": "Easy",
  "tags": ["array", "hash-map"],
  "constraints": "2 <= nums.length <= 10^4",
  "testCases": [
    { "input": "[2,7,11,15]\n9", "expectedOutput": "[0,1]" },
    { "input": "[3,2,4]\n6", "expectedOutput": "[1,2]" }
  ],
  "boilerplateCode": {
    "cpp": "#include<iostream>\nusing namespace std;\nint main(){}",
    "python": "def twoSum(nums, target):\n    pass",
    "java": "class Solution { public int[] twoSum(int[] nums, int target) { return null; } }"
  }
}

### Expected: 201
### { success: true, message: "Problem created successfully", data: { problem: {...} } }


