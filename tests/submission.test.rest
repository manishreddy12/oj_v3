### ========================================
### SUBMISSION ROUTES - Test Cases
### Base URL: http://localhost:5001/api/submissions
### ========================================


### ----------------------------------------
### 1. Submit Code - Success
### ----------------------------------------
POST http://localhost:5001/api/submissions
Content-Type: application/json

{
  "userId": "64f1a2b3c4d5e6f7a8b9c0d1",
  "problemId": "64f1a2b3c4d5e6f7a8b9c0d2",
  "language": "python",
  "sourceCode": "def twoSum(nums, target):\n    lookup = {}\n    for i, n in enumerate(nums):\n        if target - n in lookup:\n            return [lookup[target-n], i]\n        lookup[n] = i",
  "testCases": [
    { "input": "[2,7,11,15]\n9", "expectedOutput": "[0,1]" }
  ]
}

### Expected: 201
### { success: true, message: "Code submitted and judged successfully", data: { submission: {...} } }


