# ============================================
# Execution Service — Environment Variables
# ============================================

# Server
PORT=5001
NODE_ENV=development

# MongoDB (use Atlas URI for cloud deployments)
MONGO_URI=mongodb://localhost:27017/online_judge

# Microservice URLs
API_SERVICE_URL=http://localhost:5000

# CORS — allowed frontend origin
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Code Execution Mode
# 'direct' — run on host OS (local dev)
# 'docker' — run inside Docker container (EC2/production)
EXECUTION_MODE=direct

# Docker image for code execution (only used when EXECUTION_MODE=docker)
# This should be your ECR image URI in production
DOCKER_IMAGE=oj-runner:latest
