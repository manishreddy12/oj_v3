# ============================================
# API Service — Environment Variables
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (use Atlas URI for cloud deployments)
MONGO_URI=mongodb://localhost:27017/online_judge

# JWT Authentication
JWT_SECRET=supersecretkey
JWT_EXPIRY=1d

# Redis Cache
# Set to 'true' for local/Docker deployments, 'false' for Render (no Redis)
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379

# Microservice URLs
EXECUTION_SERVICE_URL=http://localhost:5001

# CORS — allowed frontend origin
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
